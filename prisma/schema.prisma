// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------
// User & HR Module
// ----------------------------------------------------------------------
model User {
  id         String    @id @default(cuid())
  name       String?
  email      String?   @unique
  password   String?
  image      String?
  role       Role      @default(STAFF)
  userRoleId String? // Relation to custom UserRole
  userRole   UserRole? @relation(fields: [userRoleId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee             Employee?
  activityLogs         ActivityLog[]
  notifications        Notification[]
  announcements        Announcement[]
  reviewedTimeRequests TimeAdjustmentRequest[]

  sentKudos                Kudos[]                   @relation("SentKudos")
  announcementInteractions AnnouncementInteraction[]

  // Phase 16
  createdQuests Quest[] @relation("CreatedQuests")

  // Phase 22: Async AI Import Jobs
  importJobs ImportJob[]
}

model UserRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]
}

model RolePermission {
  id     String   @id @default(cuid())
  roleId String
  role   UserRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  module    String // e.g. "HR", "PAYROLL", "CRM", "SETTINGS", "LEAVE"
  canRead   Boolean @default(false)
  canWrite  Boolean @default(false)
  canDelete Boolean @default(false)

  @@unique([roleId, module])
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Attendance Settings Override
  lat       Float?
  lng       Float?
  radius    Float?
  workStart String?
  workEnd   String?

  employees     Employee[]
  expenses      ExpenseRequest[]
  announcements Announcement[]
}

model Employee {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // Core Profile
  image             String? // Store URL or path for employee avatar picture
  phoneNumber       String?
  idCardNumber      String?
  dob               DateTime? @db.Date
  gender            String?
  address           String?
  emergencyContact  String?
  emergencyRelation String?

  // Culture & Fit
  mbti          String?
  enneagram     String?
  tshirtSize    String?
  foodAllergies String?

  // Employment Details
  employeeType     EmployeeType @default(MONTHLY)
  position         String?
  wageRate         Float        @default(0) // เงินเดือน หรือ ค่าแรงรายวัน
  startDate        DateTime?    @db.Date
  probationEndDate DateTime?    @db.Date
  status           Status       @default(ACTIVE)
  bankAccount      String?

  managerId    String?
  manager      Employee?  @relation("EmployeeToManager", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates Employee[] @relation("EmployeeToManager")

  // Attendance Settings Override (Individual)
  customLat       Float?
  customLng       Float?
  customRadius    Float?
  customWorkStart String?
  customWorkEnd   String?

  attendances     Attendance[]
  leaveRequests   LeaveRequest[]
  leaveBalances   LeaveBalance[]
  payrolls        Payroll[]
  documents       EmployeeDocument[]
  approvals       ExpenseRequest[]        @relation("ExpenseApprover")
  requests        ExpenseRequest[]        @relation("ExpenseRequestor")
  timeLogs        TimeLog[]
  timeAdjustments TimeAdjustmentRequest[]

  moods            EmployeeMood[]
  receivedKudos    Kudos[]           @relation("ReceivedKudos")
  goals            EmployeeGoal[]
  overtimeRequests OvertimeRequest[]

  // Phase 16: Core HR & Gamification Hooks
  jobPositionId String?
  jobPosition   JobPosition? @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)
  level         Int          @default(1)
  exp           Int          @default(0)
  coins         Int          @default(0)

  skills         EmployeeSkill[]
  assignedQuests Quest[]         @relation("AssignedQuests")
  questLogs      QuestLog[]
  okrKeyResults  OkrKeyResult[]

  // Initiatives (Action Plans)
  ownedInitiatives        Initiative[] @relation("InitiativeOwner")
  collaboratedInitiatives Initiative[] @relation("InitiativeCollaborators")
}

enum EmployeeType {
  MONTHLY
  DAILY
}

enum Status {
  ACTIVE
  INACTIVE
}

model Attendance {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date        DateTime  @db.Date // วันที่ทำงาน
  checkIn     DateTime?
  checkOut    DateTime?
  hoursWorked Float?
  notes       String?
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type      LeaveType
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date

  // Phase 15: Hourly Leave Extensions
  startTime      String? // e.g. "09:00"
  endTime        String? // e.g. "12:00"
  requestedHours Float   @default(8) // Used to deduct from `LeaveBalance` precisely

  reason        String?
  attachmentUrl String? // For medical certificates
  status        ApprovalStatus @default(PENDING)
  approvedBy    String? // Store user ID who approved

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LeaveType {
  SICK
  VACATION
  PERSONAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveBalance {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  year               Int
  sickLeaveTotal     Float @default(30)
  sickLeaveUsed      Float @default(0)
  personalLeaveTotal Float @default(6)
  personalLeaveUsed  Float @default(0)
  vacationTotal      Float @default(6)
  vacationUsed       Float @default(0)

  @@unique([employeeId, year])
}

model CompanySetting {
  id               String    @id @default(cuid())
  defaultLat       Float?
  defaultLng       Float?
  defaultRadius    Float     @default(100)
  defaultWorkStart String    @default("09:00")
  defaultWorkEnd   String    @default("18:00")
  
  // Phase 29: Global Settings & Data Architecture
  financeGoLiveDate DateTime?
  
  updatedAt        DateTime  @updatedAt
}

model TimeLog {
  id           String    @id @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date         DateTime  @db.Date
  checkInTime  DateTime?
  checkInLat   Float?
  checkInLng   Float?
  checkOutTime DateTime?
  checkOutLat  Float?
  checkOutLng  Float?
  status       String    @default("ON_TIME") // ON_TIME, LATE, ABSENT, HALF_DAY
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([employeeId, date])
}

// ----------------------------------------------------------------------
// Overtime Management (Phase 15)
// ----------------------------------------------------------------------

model OvertimeRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date            DateTime @db.Date
  startTime       String // e.g. "18:00"
  endTime         String // e.g. "21:00"
  calculatedHours Float
  multiplier      Float    @default(1.5) // Standard 1.5x OT Rate
  reason          String?

  status     ApprovalStatus @default(PENDING)
  approvedBy String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model Payroll {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  month       String // "YYYY-MM"
  baseSalary  Float
  otAmount    Float  @default(0)
  otherIncome Float  @default(0) // รายได้อื่นๆ เพิ่มเติม
  bonus       Float  @default(0)

  socialSecurityDeduction Float @default(0) // ประกันสังคม (Max 750)
  taxDeduction            Float @default(0) // ภาษีหัก ณ ที่จ่าย
  lateDeduction           Float @default(0) // หักสาย/ขาดงาน
  deductions              Float @default(0) // หักอื่นๆ รวม

  netSalary Float
  status    PaymentStatus @default(UNPAID)

  transaction Transaction?
}

enum PaymentStatus {
  UNPAID
  PAID
}

model EmployeeDocument {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type    DocumentType
  title   String
  fileUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DocumentType {
  PAYSLIP
  WARNING_LETTER
  CONTRACT
  MEDICAL_CERT
  OTHER
}

// ----------------------------------------------------------------------
// CRM Module
// ----------------------------------------------------------------------
model Customer {
  id          String  @id @default(cuid())
  name        String
  profileName String? // The social media handle (e.g. Line Display Name, FB Name)
  phone       String?
  address     String?

  // Advanced Geographic Segmentation
  province    String?
  district    String?
  subdistrict String?
  postalCode  String?

  source String? // Facebook, Shopee, TikTok

  tags       String? // e.g "VIP, Returning" JSON string or comma separated
  totalSpent Float   @default(0)

  // AI Caching
  aiPsychology String?
  aiNextAction String?
  aiChurnRisk  String?
  aiLastSync   DateTime?

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders           Order[]
  aliases          CustomerAlias[]
  resolvingMatches ResolutionMatch[] @relation("resolvingCustomer")
  duplicateMatches ResolutionMatch[] @relation("duplicateCustomer")
}

model CustomerAlias {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  name        String?
  profileName String?
  phone       String?
  source      String?

  createdAt DateTime @default(now())
}

model ResolutionMatch {
  id               String   @id @default(cuid())
  masterCustomerId String
  masterCustomer   Customer @relation("resolvingCustomer", fields: [masterCustomerId], references: [id], onDelete: Cascade)

  duplicateCustomerId String
  duplicateCustomer   Customer @relation("duplicateCustomer", fields: [duplicateCustomerId], references: [id], onDelete: Cascade)

  confidenceScore Float // 0.0 to 1.0 Jaro-Winkler/LLM Score
  status          MatchStatus @default(PENDING) // PENDING, MERGED, REJECTED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MatchStatus {
  PENDING
  MERGED
  REJECTED
}

// ----------------------------------------------------------------------
// Product & Inventory Module
// ----------------------------------------------------------------------
model Product {
  id        String  @id @default(cuid())
  name      String
  sku       String? @unique
  costPrice Float   @default(0) // ต้นทุนหลักเป็นบาท
  salePrice Float   @default(0)
  stock     Int     @default(0)
  images    String? // JSON string or comma separated URLs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems      OrderItem[]
  channelProducts ChannelProduct[]
  inventoryLogs   InventoryLog[]
}

model ChannelProduct {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  channel     SalesChannel
  platformSku String // The SKU or ID on the platform (e.g., Shopee Variation ID)

  @@unique([channel, platformSku])
}

// ----------------------------------------------------------------------
// Pre-order Module
// ----------------------------------------------------------------------
model PreorderBatch {
  id        String         @id @default(cuid())
  batchName String // "รอบกุมภาพันธ์ - สินค้า A"
  status    PreorderStatus @default(COLLECTING)

  orderDate        DateTime? // วันสั่งจีน
  estimatedArrival DateTime? // วันคาดว่าถึงไทย

  costRMB      Float? // ต้นทุนหยวน
  exchangeRate Float? // เรทเงินหยวน-บาท
  costTHB      Float? // ต้นทุนรวมบาท
  shippingCost Float? // ค่าขนส่งเข้าไทย

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PreorderItem[]
}

enum PreorderStatus {
  COLLECTING
  ORDERED_FROM_CHINA
  SHIPPING_TO_THAI
  ARRIVED
  COMPLETED
}

model PreorderItem {
  id            String        @id @default(cuid())
  preorderBatch PreorderBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId       String

  productName    String
  quantity       Int
  costPerUnitRMB Float?
  customerName   String? // กรณีไม่ได้ลิงก์กับ CRM ตรง
  notes          String?
}

// ----------------------------------------------------------------------
// Order Management Module (OMS) & Inventory Ledger
// ----------------------------------------------------------------------
enum MovementCategory {
  INBOUND // รับของเข้าคลัง (Supplier/Restock)
  OUTBOUND // ตัดยอดขายอัตโนมัติ (Sales/E-Commerce)
  ADJUSTMENT // อัปเดตยอดจริง (Cycle Count/Damage/Lost/Audit)
  RETURN // ลูกค้าตีของกลับ
}

model InventoryLog {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  type            MovementCategory
  quantityChanged Int // Positive (+) or Negative (-)
  balanceAfter    Int // The snapshot of stock after this movement

  reference String? // PlatformOrderId, PO ID, etc.
  notes     String? // User manual notes or systemic auto-notes

  createdBy String? // Which employee/system triggered this log?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([type])
}

// ----------------------------------------------------------------------
// Order Management Module
// ----------------------------------------------------------------------
model Order {
  id              String  @id @default(cuid())
  platformOrderId String?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  channel      SalesChannel // Shopee, TikTok, LINE SHOPPING, etc.
  status       OrderStatus  @default(PENDING)
  isReconciled Boolean      @default(false)

  subtotal    Float
  shippingFee Float @default(0)
  platformFee Float @default(0)
  discount    Float @default(0)
  total       Float

  notes String?

  createdAt DateTime @default(now()) // Can be order date from platform
  updatedAt DateTime @updatedAt

  items           OrderItem[]
  reconciliations OrderReconciliation[]

  @@unique([platformOrderId, channel])
}

enum SalesChannel {
  SHOPEE
  LAZADA
  TIKTOK
  LINESHOPPING
  FACEBOOK
  IG
  POS
  OTHER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  SHIPPING
  DELIVERED
  COMPLETED
  CANCELLED
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  productName String // เก็บไว้เผื่อสินค้าโดนลบ
  quantity    Int
  price       Float // ราคาตอนขาย
}

// ----------------------------------------------------------------------
// Financial Module
// ----------------------------------------------------------------------
model Transaction {
  id          String          @id @default(uuid())
  type        TransactionType
  amount      Float           @default(0) // Platform currency
  amountTHB   Float           @default(0) // Converted to THB
  date        DateTime        @default(now())
  category    String? // e.g., "AD_SPEND", "SALES_REVENUE", "PAYROLL", "PROCUREMENT"
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt

  expenseRequestId String?         @unique
  expenseRequest   ExpenseRequest? @relation(fields: [expenseRequestId], references: [id])

  payrollId String?  @unique
  payroll   Payroll? @relation(fields: [payrollId], references: [id])

  reconciliations OrderReconciliation[]
}

model OrderReconciliation {
  id            String @id @default(cuid())
  orderId       String
  transactionId String

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  amountMatched Float // ยอดเงินที่เจียดจาก Transaction ไปปกคลุม Order นี้

  createdAt DateTime @default(now())
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

// ---------------------------------------------------------------------------
// Procurement & Expense Management (Phase 8)
// ---------------------------------------------------------------------------

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model ExpenseRequest {
  id           String        @id @default(uuid())
  title        String
  description  String?
  amount       Float         @default(0)
  status       ExpenseStatus @default(PENDING)
  expectedDate DateTime?
  category     String? // e.g. "OFFICE_SUPPLIES", "MARKETING", "INVENTORY"
  vendorName   String?
  receiptUrl   String?

  requestorId String
  requestor   Employee @relation("ExpenseRequestor", fields: [requestorId], references: [id])

  // Optional depending on if tied to a specific department cost-center
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  approverId String?
  approver   Employee? @relation("ExpenseApprover", fields: [approverId], references: [id])

  items       ExpenseItem[]
  transaction Transaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExpenseItem {
  id               String         @id @default(uuid())
  expenseRequestId String
  expenseRequest   ExpenseRequest @relation(fields: [expenseRequestId], references: [id], onDelete: Cascade)

  itemName String
  quantity Int    @default(1)
  price    Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Currency {
  THB
  RMB
  USD
}

enum TransactionCategory {
  PRODUCT_COST // 📦 ต้นทุนสินค้า
  ADVERTISING // 📢 ค่าโฆษณา
  SHIPPING // 🚚 ค่าขนส่ง
  PAYROLL // 👥 ค่าพนักงาน
  OPERATIONAL // 🏢 ค่าดำเนินงาน
  OTHER // 📋 อื่นๆ
  SALES_REVENUE // 💰 รายได้จากการขาย (จากระบบออเดอร์)
}

// ----------------------------------------------------------------------
// Ads Tracking Module
// ----------------------------------------------------------------------
model AdSpend {
  id       String       @id @default(cuid())
  date     DateTime     @db.Date
  platform SalesChannel

  amountSpent Float
  reach       Int?
  clicks      Int?
  orders      Int? // ออเดอร์ที่เกิดจากแอด

  notes String?
}

// ----------------------------------------------------------------------
// System Module
// ----------------------------------------------------------------------
model ActivityLog {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action   String // "CREATE", "UPDATE", "DELETE", "LOGIN"
  entity   String // "ORDER", "PRODUCT", "EMPLOYEE"
  entityId String?
  details  String?

  timestamp DateTime @default(now())
}

// ----------------------------------------------------------------------
// Noticenter & Broadcast Module (Phase 12)
// ----------------------------------------------------------------------

model Notification {
  id     String @id @default(cuid())
  userId String // The User who receives this notification
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  message     String
  type        String  @default("SYSTEM") // e.g. "ATTENDANCE_REQUEST", "ANNOUNCEMENT", "PAYROLL"
  isRead      Boolean @default(false)
  referenceId String? // Optional ID for deep linking (e.g. ID of the specific Request)

  createdAt DateTime @default(now())
}

model TimeAdjustmentRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date              DateTime  @db.Date // The date they want to edit
  requestedCheckIn  DateTime?
  requestedCheckOut DateTime?
  reason            String

  status ApprovalStatus @default(PENDING) // PENDING, APPROVED, REJECTED

  reviewerId   String? // The HR/Manager who reviewed it
  reviewer     User?     @relation(fields: [reviewerId], references: [id])
  reviewedAt   DateTime?
  adminComment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id      String @id @default(cuid())
  title   String
  content String

  authorId String // The User who posted it
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  isGlobal           Boolean     @default(true) // If true, sent to everyone
  targetDepartmentId String? // If false, sent to specific department
  department         Department? @relation(fields: [targetDepartmentId], references: [id], onDelete: SetNull)

  isActive Boolean @default(true)

  // Phase 13 Engagement Additions
  type         String?                   @default("NEWS") // "NEWS", "EVENT", "POLL"
  eventDate    DateTime? // If type="EVENT", when does this happen?
  pollOptions  Json? // If type="POLL", ["Pizza", "KFC"]
  interactions AnnouncementInteraction[]

  // Phase 14: Lifecycle Management
  publishAt DateTime? // Optional start date for visibility
  expireAt  DateTime? // Optional end date for visibility

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------------
// Employee Engagement Module (Phase 13)
// ----------------------------------------------------------------------

model EmployeeMood {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  mood       MoodType
  note       String?
  createdAt  DateTime @default(now())

  @@unique([employeeId, date])
}

enum MoodType {
  GREAT
  GOOD
  OKAY
  BAD
  TERRIBLE
}

model Kudos {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("SentKudos", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   Employee @relation("ReceivedKudos", fields: [receiverId], references: [id], onDelete: Cascade)
  badgeType  String   @default("THANK_YOU")
  message    String
  createdAt  DateTime @default(now())
}

model EmployeeGoal {
  id           String     @id @default(cuid())
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  currentValue Float      @default(0)
  targetValue  Float
  unit         String     @default("%")
  deadline     DateTime?  @db.Date
  status       GoalStatus @default(IN_PROGRESS)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum GoalStatus {
  IN_PROGRESS
  ACHIEVED
  MISSED
}

model AnnouncementInteraction {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  action         String // "RSVP_YES", "VOTE_1", "LIKE"
  createdAt      DateTime     @default(now())

  @@unique([announcementId, userId, action])
}

// ----------------------------------------------------------------------
// Phase 16: Gamification & Core HR
// ----------------------------------------------------------------------

model JobPosition {
  id          String  @id @default(cuid())
  title       String
  description String?
  minSalary   Float   @default(0)
  maxSalary   Float   @default(0)

  employees    Employee[]
  competencies JobPositionCompetency[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Competency {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  positions JobPositionCompetency[]
  skills    EmployeeSkill[]
}

model JobPositionCompetency {
  id            String @id @default(cuid())
  jobPositionId String
  competencyId  String
  requiredLevel Int    @default(1) // 1-5 Scale

  jobPosition JobPosition @relation(fields: [jobPositionId], references: [id], onDelete: Cascade)
  competency  Competency  @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@unique([jobPositionId, competencyId])
}

model EmployeeSkill {
  id           String @id @default(cuid())
  employeeId   String
  competencyId String
  currentLevel Int    @default(1)

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  competency Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@unique([employeeId, competencyId])
}

enum InitiativeStatus {
  PENDING
  IN_PROGRESS
  REVIEWING
  COMPLETED
  OVERDUE
}

enum InitiativeHealth {
  ON_TRACK
  AT_RISK
  OFF_TRACK
}

model Initiative {
  id          String           @id @default(cuid())
  title       String
  description String?
  status      InitiativeStatus @default(PENDING)
  health      InitiativeHealth @default(ON_TRACK)
  progress    Int              @default(0) // 0-100 Auto calculated

  startDate DateTime
  endDate   DateTime

  expReward  Int @default(500)
  coinReward Int @default(100)

  keyResultId String
  keyResult   OkrKeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)

  ownerId String
  owner   Employee @relation("InitiativeOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  collaborators Employee[] @relation("InitiativeCollaborators")

  quests Quest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quest {
  id          String    @id @default(cuid())
  title       String
  description String?
  expReward   Int       @default(10)
  coinReward  Int       @default(0)
  deadline    DateTime? @db.Date

  assignedToId String?
  assignedTo   Employee? @relation("AssignedQuests", fields: [assignedToId], references: [id], onDelete: SetNull)

  creatorId String
  creator   User   @relation("CreatedQuests", fields: [creatorId], references: [id], onDelete: Cascade)

  initiativeId String?
  initiative   Initiative? @relation(fields: [initiativeId], references: [id], onDelete: SetNull)

  status     QuestStatus @default(OPEN)
  orderIndex Float       @default(0)
  logs       QuestLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuestLog {
  id         String @id @default(cuid())
  questId    String
  employeeId String // Who claimed/completed it

  quest    Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  status      QuestStatus @default(IN_PROGRESS)
  completedAt DateTime?

  @@unique([questId, employeeId])
}

enum QuestStatus {
  OPEN
  IN_PROGRESS
  REVIEWING
  COMPLETED
  FAILED
}

model OkrObjective {
  id          String  @id @default(cuid())
  title       String
  description String?
  year        Int
  quarter     Int?

  keyResults OkrKeyResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OkrKeyResult {
  id          String       @id @default(cuid())
  objectiveId String
  objective   OkrObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  title        String
  targetValue  Float
  currentValue Float  @default(0)
  unit         String @default("%")

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  initiatives Initiative[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Marketing & Ad Spend Module (Dashboard Core)
// ---------------------------------------------------------------------------

model MarketingCampaign {
  id       String @id @default(cuid())
  name     String
  platform String // e.g., "FACEBOOK", "GOOGLE", "TIKTOK"
  status   String @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED

  dailyBudget Float @default(0)
  totalSpend  Float @default(0)

  startDate DateTime  @db.Date
  endDate   DateTime? @db.Date

  logs AdSpendLog[]
}

model AdSpendLog {
  id         String            @id @default(cuid())
  campaignId String
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  date        DateTime @db.Date
  spend       Float // Amount spent on this day
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0) // Mapped directly or inferred

  createdAt DateTime @default(now())

  @@unique([campaignId, date])
}

// ----------------------------------------------------------------------
// Phase 22: Async AI Background Jobs
// ----------------------------------------------------------------------
model ImportJob {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileName String
  fileSize Int
  status   JobStatus @default(PENDING) // PENDING, PROCESSING, COMPLETED, FAILED

  errorLog   String?
  resultJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
